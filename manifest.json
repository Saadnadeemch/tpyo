{
  "manifest_version": 3,
  "name": "Tpyo",
  "version": "1.0.0",
  "description": "Humanize your Dm's.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["prompt.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tpyo — Humanize your response",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "trigger-tpyo": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Trigger Tpyo Humanizer panel on active field"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon.png", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}